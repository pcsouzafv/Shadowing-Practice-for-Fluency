# ─────────────────────────────────────────────────────────────────────────────
# Shadowing Practice for Fluency — Exemplo de variáveis de ambiente
# Copie para .env e preencha com seus valores reais
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── APIs de IA ───────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENAI_API_KEY=
LMNT_API_KEY=

DEEPGRAM_API_KEY=
DEEPGRAM_ENABLED=1

# ── Ollama (IA local) ─────────────────────────────────────────────────────────
OLLAMA_ENABLED=1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SEC=90

# ── Piper TTS (local) ────────────────────────────────────────────────────────
PIPER_ENABLED=1

# ── PostgreSQL adaptativo (opcional) ────────────────────────────────────────
# Use `disabled` para desligar a camada adaptativa sem tentar conexao.
# Python local: postgresql://idiomasbr:idiomasbr123@localhost:5433/idiomasbr
# Docker Desktop: postgresql://idiomasbr:idiomasbr123@host.docker.internal:5433/idiomasbr
DATABASE_URL=disabled

# ── Whisper (transcrição local) ───────────────────────────────────────────────
LOCAL_WHISPER_ENABLED=1
LOCAL_WHISPER_MODEL=tiny
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8

# ── YouTube / yt-dlp (opcional, recomendado em Docker/servidor) ─────────────
# Em Docker, prefira um cookies.txt exportado do navegador em formato Netscape.
# Coloque o arquivo em config/youtube-cookies.txt e descomente:
# YTDLP_COOKIES_FILE=config/youtube-cookies.txt
#
# Fora do container, voce tambem pode tentar ler os cookies direto do navegador:
# YTDLP_COOKIES_FROM_BROWSER=edge
# Exemplos validos: chrome, chrome:Default, firefox, edge
#
# Proxy opcional para contornar bloqueio/IP ban:
# YTDLP_PROXY_URL=http://usuario:senha@host:porta
# YOUTUBE_TRANSCRIPT_PROXY_URL=http://usuario:senha@host:porta
#
# Delays opcionais para reduzir bot-check/429 em carga maior:
# YTDLP_SLEEP_REQUESTS_SEC=0.75
# YTDLP_SLEEP_INTERVAL_SEC=5
# YTDLP_MAX_SLEEP_INTERVAL_SEC=8

# ── WhatsApp Mini-Aulas ───────────────────────────────────────────────────────
# Ative para iniciar o serviço de mini-aulas via WhatsApp
WHATSAPP_ENABLED=0

# URL do Evolution API (localhost em dev, URL do Docker em prod)
EVOLUTION_API_URL=http://localhost:8080

# Chave de autenticação da sua instância Evolution API
# Deve coincidir com AUTHENTICATION_API_KEY no docker-compose.yml
EVOLUTION_API_KEY=changeme-secret-key

# Nome da instância no Evolution API
EVOLUTION_INSTANCE=shadowing

# URL pública do servidor (necessária para o QR Code e webhook)
# Em desenvolvimento local: use a URL do ngrok (ex: https://abc123.ngrok.io)
# Em produção: use o domínio real (ex: https://meusite.com)
EVOLUTION_SERVER_URL=http://localhost:8080

# ── Docker ────────────────────────────────────────────────────────────────────
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ── Elastic Stack (perfil opcional do Docker Compose) ───────────────────────
# Suba com:
# docker compose --profile elastic up -d elasticsearch kibana metricbeat
ELASTIC_STACK_VERSION=7.15.1
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300
ELASTICSEARCH_CLUSTER_NAME=shadowing-practice
ELASTICSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
KIBANA_PORT=5601
KIBANA_NODE_OPTIONS=--max-old-space-size=512

# Opcional: reutilizar um volume Docker ja existente para manter os dados
# ELASTICSEARCH_DATA_VOLUME=shadowingpracticeforfluency_elasticsearch_data
# ELASTICSEARCH_DATA_VOLUME_EXTERNAL=true
